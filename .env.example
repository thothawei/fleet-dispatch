# App
APP_PORT=8080
APP_ENV=local

# PostgreSQL
DB_HOST=postgis
DB_PORT=5432
# 本機 GUI（Postico 等）連 Docker PostGIS 用此 port；避開 Mac 本機 postgres 的 5432
DB_HOST_PORT=5433
DB_NAME=fleet
DB_USER=fleet
DB_PASSWORD=change_me
# 每條 SQL 的執行上限（毫秒），逾時由 Postgres 中止，防跑飛全表掃描拖垮線上（F9-4）。0=不設限。
DB_STATEMENT_TIMEOUT_MS=10000

# Redis
REDIS_ADDR=redis:6379

# LINE
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LIFF_ID=

# OSRM（預設用公開 demo server；自架請改 http://osrm:5000）
OSRM_URL=http://router.project-osrm.org

# JWT（A1 司機認證）— 正式環境務必改成強隨機值
JWT_SECRET=dev-secret-change-me
JWT_EXPIRY_HOURS=72

# Dispatch 參數（M2 起用；A2 逾時重派）
DISPATCH_RADIUS_M=3000
DISPATCH_MAX_DRIVERS=5
DISPATCH_OFFER_TIMEOUT_SEC=20
DISPATCH_MAX_ATTEMPTS=3
DRIVER_OFFLINE_SEC=60

# ETA 推播節流（A4）：距上次推播 >N 秒 或 司機移動 >M 公尺 才推
ETA_PUSH_MIN_INTERVAL_SEC=30
ETA_PUSH_DIST_THRESHOLD_M=300

# 軌跡分區維護（A5）：啟動時預建未來 N 個月分區；保留月數 0=不自動刪舊分區
TRACK_PARTITION_MONTHS_AHEAD=2
TRACK_RETENTION_MONTHS=0

# WebSocket 即時通道（M5-WS）
WS_WRITE_WAIT_SEC=10
WS_PONG_WAIT_SEC=60
WS_MAX_MESSAGE_BYTES=4096

# 後台管理員種子（帳號/密碼；首次啟動且尚無任何 admin 時建立）
# docker-compose 預設已帶 admin/admin，這裡留空即沿用預設；要改帳密在此覆蓋
ADMIN_SEED_USERNAME=
ADMIN_SEED_PASSWORD=

# FCM 真推播（A2）：Firebase 服務帳戶 JSON 路徑（容器內路徑）
# 留空＝不啟用，App 推播走 stub（只記 log，不真的推）；派單路徑不受影響
# 取得：Firebase Console → 專案設定 → 服務帳戶 → 產生新的私密金鑰
FCM_CREDENTIALS_FILE=
