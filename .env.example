# App
APP_PORT=8080
APP_ENV=local

# PostgreSQL
DB_HOST=postgis
DB_PORT=5432
DB_NAME=fleet
DB_USER=fleet
DB_PASSWORD=change_me

# Redis
REDIS_ADDR=redis:6379

# LINE
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LIFF_ID=

# OSRM（預設用公開 demo server；自架請改 http://osrm:5000）
OSRM_URL=http://router.project-osrm.org

# JWT（A1 司機認證）— 正式環境務必改成強隨機值
JWT_SECRET=dev-secret-change-me
JWT_EXPIRY_HOURS=72

# Dispatch 參數（M2 起用；A2 逾時重派）
DISPATCH_RADIUS_M=3000
DISPATCH_MAX_DRIVERS=5
DISPATCH_OFFER_TIMEOUT_SEC=20
DISPATCH_MAX_ATTEMPTS=3
DRIVER_OFFLINE_SEC=60

# ETA 推播節流（A4）：距上次推播 >N 秒 或 司機移動 >M 公尺 才推
ETA_PUSH_MIN_INTERVAL_SEC=30
ETA_PUSH_DIST_THRESHOLD_M=300

# 軌跡分區維護（A5）：啟動時預建未來 N 個月分區；保留月數 0=不自動刪舊分區
TRACK_PARTITION_MONTHS_AHEAD=2
TRACK_RETENTION_MONTHS=0
